# --- Google Cloud (Gmail readonly OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI registered on the OAuth client.
# Local: http://localhost:3000/api/auth/google/callback
# Prod:  https://<your-vercel-domain>/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Base URL of this app, used to build the OAuth redirect and the published ICS link.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IANA timezone the family lives in — used to interpret extracted times and
# compute "today"/"this week" boundaries, since the server runtime's own
# timezone (UTC on Vercel) is not the family's.
APP_TIMEZONE=America/Chicago

# --- Supabase ---
SUPABASE_URL=
# Service role key — server-only, never exposed to the client. Single-household
# app, so API routes talk to Supabase directly with this key (no per-user RLS).
SUPABASE_SERVICE_ROLE_KEY=
# Anon key + URL for Supabase Auth only (login) — safe to expose client-side.
# Find both under Project Settings -> API. URL is the same as SUPABASE_URL above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Gemini ---
GEMINI_API_KEY=
# Flash-tier only, per cost rules in CLAUDE.md.
GEMINI_MODEL=gemini-2.5-flash

# --- Ingestion config ---
# Comma-separated name:context pairs to help Gemini attribute items to a kid.
# Names here are placeholders — replace with your kids' real names.
KIDS=Aarav:2nd grade at May Watts Elementary,Diya:Little Sprouts daycare

# Comma-separated parent names, used for task assignment on the Lists screen.
PARENTS=Lav,Pratik

# --- ICS publish (private feed parents subscribe to) ---
# Long random token — treat like a password. Generate with:
#   openssl rand -hex 24
ICS_PUBLISH_TOKEN=

# --- Cron protection ---
# Vercel Cron sends this value in an `Authorization: Bearer <CRON_SECRET>` header;
# ingestion routes reject requests without it. Generate with: openssl rand -hex 24
CRON_SECRET=

# --- Web push (PWA notifications) ---
# Generate with: npx web-push generate-vapid-keys
# Public key is also read client-side to create the push subscription.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Access protection (Supabase Auth, Google sign-in) ---
# No allowlist env var anymore — who can sign in is governed by
# household_members (any Google account can authenticate; membership is
# what actually gates access to a specific family's data). Requires the
# Google provider enabled in the Supabase dashboard, reusing the OAuth
# client above (add the Supabase callback URL to its Authorized redirect
# URIs). ALLOWED_EMAILS is still read by scripts/migrate-to-households.ts
# — the one-time migration for installs upgrading from the old
# single-household allowlist model — but is otherwise unused.
